{
  "name": "@apitree.cz/eslint-config",
  "version": "2.2.1",
  "description": "ESLint configuration for ApiTree projects.",
  "keywords": [
    "apitree",
    "eslint",
    "config",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ApiTreeCZ/toolbox",
    "directory": "packages/eslint-config"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rules": {
      "types": "./dist/base/rules/index.d.ts",
      "import": "./dist/base/rules/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "del dist tsconfig.build.tsbuildinfo",
    "build": "tsc --build tsconfig.build.json",
    "cleanup": "del .eslintcache .turbo tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo coverage dist node_modules",
    "fix": "turbo run ts format:fix lint:fix",
    "format": "prettier --check \"./**/*.{js,json,md,ts}\"",
    "format:fix": "pnpm run format --write",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "qa": "turbo run ts format lint",
    "ts": "tsc --build tsconfig.json"
  },
  "dependencies": {
    "@eslint/core": "^1.2.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^65.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": "^9.39.0",
    "typescript": "^5.9.3 || ^6.0.2"
  }
}
