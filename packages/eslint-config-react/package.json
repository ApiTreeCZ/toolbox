{
  "name": "@apitree.cz/eslint-config-react",
  "version": "3.0.0",
  "description": "ESLint configuration for React projects in ApiTree.",
  "keywords": [
    "apitree",
    "eslint",
    "config",
    "react",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ApiTreeCZ/toolbox",
    "directory": "packages/eslint-config-react"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "del dist tsconfig.build.tsbuildinfo",
    "build": "tsc --build tsconfig.build.json",
    "cleanup": "del .eslintcache .turbo tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo dist node_modules",
    "fix": "turbo run ts format:fix lint:fix",
    "format": "prettier --check \"./**/*.{js,json,md,ts}\"",
    "format:fix": "pnpm run format --write",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "qa": "turbo run ts format lint",
    "ts": "tsc --build tsconfig.json"
  },
  "dependencies": {
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-formatjs": "^6.4.13",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-mdx": "^3.8.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.6.0"
  },
  "devDependencies": {
    "@apitree.cz/eslint-config": "workspace:*",
    "eslint": "^9.39.4",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@apitree.cz/eslint-config": "workspace:*",
    "eslint": "^9.39.0",
    "react": "^19.0.0"
  }
}
